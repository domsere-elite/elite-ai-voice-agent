# ── LiveKit Cloud credentials (the ONLY keys you need) ─────────────────
# All AI models (LLM, STT, TTS) are served through LiveKit Inference.
# No separate OpenAI, Deepgram, or Telnyx API keys required.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Model overrides (optional — sensible defaults are set in code) ─────
# STT_MODEL=deepgram/nova-3
# LLM_MODEL=openai/gpt-4.1
# TTS_MODEL=deepgram/aura-2
# TTS_VOICE=apollo

# ── CRM ────────────────────────────────────────────────────────────────
CRM_BASE_URL=https://crm.eliteportmgmt.com/api/voice

# ── SIP ────────────────────────────────────────────────────────────────
SIP_TRUNK_ID=
SPECIALIST_PHONE=+18333814416
