# LiveKit Cloud credentials
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# LLM provider
OPENAI_API_KEY=

# Telnyx — STT + TTS (used by default when USE_TELNYX_MEDIA=true)
TELNYX_API_KEY=
TELNYX_TTS_VOICE=Telnyx.NaturalHD.astra
USE_TELNYX_MEDIA=true

# Fallback: direct Deepgram STT (used when USE_TELNYX_MEDIA=false)
DEEPGRAM_API_KEY=

# CRM base URL (no trailing slash)
CRM_BASE_URL=https://crm.eliteportmgmt.com/api/voice

# SIP trunk ID for outbound transfers
SIP_TRUNK_ID=
# Specialist transfer number
SPECIALIST_PHONE=+18333814416
